@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C4 Container Diagram – Интернет-газета

Person(user, "Пользователь")

System_Boundary(system, "Интернет-газета") {

  Container(web, "Web Application", "React / Vue", "UI для пользователей")
  
  Container(api, "Backend API", "Spring Boot / Node.js", "Бизнес-логика и REST API")
  
  Container(db, "Database", "PostgreSQL", "Хранение данных")
  
  Container(storage, "Media Storage", "S3 / File Storage", "Хранение медиа")
}

Rel(user, web, "Использует")
Rel(web, api, "REST API")
Rel(api, db, "CRUD операции")
Rel(api, storage, "Загрузка/получение файлов")

@enduml