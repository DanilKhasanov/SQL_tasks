@startuml
!theme plain
title Диаграмма активности – Процесс публикации статьи

|Автор|
start
:Создать статью (черновик);
:Загрузить медиа (опционально);
:Присвоить теги;
:Отправить на рецензирование;

|Редактор|
:Проверить статью;

if (Статья одобрена?) then (да)
  :Опубликовать статью;
  :Установить статус = ОПУБЛИКОВАНО;
  stop
else (нет)
  if (Требуются изменения?) then (да)
    :Запросить изменения;
    |Автор|
    :Редактировать статью;
    :Отправить повторно;
    |Редактор|
    :Проверить снова;
    else
    :Архивировать статью;
    :Установить статус = В АРХИВЕ;
    stop
  endif
endif

|Администратор|
start
:Управлять категориями;
:Управлять тегами;
stop
@enduml
